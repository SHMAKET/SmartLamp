{
  "name": "smartlamp",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "build": "npm-run-all build:*",
    "build:css": "tailwindcss -i src_web/main.css -o data/web/styles.css --minify",
    "build:html": "html-minifier-terser --input-dir src_web --output-dir data/web --file-ext html --collapse-whitespace --remove-comments",
    "build:js": "terser src_web/app.js -o data/web/script.js -c -m",

    "dev": "npm-run-all --parallel dev:*",
    "dev:css": "tailwindcss -i src_web/main.css -o data/web/styles.css --watch",
    "dev:html": "chokidar \"src_web/**/*.html\" -c \"npm run build:html\"",
    "dev:js": "chokidar \"src_web/app.js\" -c \"npm run build:js\"",

    "upload": "npm run build && pio run --target uploadfs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SHMAKET/SmartLamp.git"
  },
  "keywords": [],
  "author": "SHMAKET",
  "license": "GPLv3",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/SHMAKET/SmartLamp/issues"
  },
  "homepage": "https://github.com/SHMAKET/SmartLamp#readme",
  "devDependencies": {
    "chokidar-cli": "^3.0.0",
    "html-minifier-terser": "^7.2.0",
    "npm-run-all": "^4.1.5",
    "tailwindcss": "^3.4.19",
    "terser": "^5.46.0"
  }
}
